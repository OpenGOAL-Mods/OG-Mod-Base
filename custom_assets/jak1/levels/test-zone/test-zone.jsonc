    },

    {
      "trans": [0.0, 50.0, 31.0],
      "etype": "linear-plat",
      "game_task": 0,
      "quat": [0, 0, 0, 1],
      "bsphere": [0.0, 50.0, 31.0, 10],
      "lump": {
        "name": "linear-plat-3",
        "path": ["vector4m",
          [0.0, 50.0, 31.0, 1.0],
          [0.0, 50.0, 31.0, 1.0],
          [0.0, 60.0, 31.0, 1.0],
          [0.0, 50.0, 31.0, 1.0],
