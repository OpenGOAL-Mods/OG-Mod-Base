;;-*-Lisp-*-
(in-package goal)

(define *casboss-airlock-data* (new 'static 'boxed-array :type airlock-data
              (static-airlock-data 
                :airlock-name "cas-front-door-3"
                :on-notice '(when #t '(casboss))
                :on-activate #f
                :on-enter #f
                :on-exit #f
                :on-cross #f
                :on-inside #f
                :on-deactivate #f
                )
              )
  )
